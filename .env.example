# Community Hero Environment Variables Example
# Copy this file to .env and fill in your actual values.

# The port your server will run on (default 3000)
PORT=3000

# Your Google Gemini API Key for AI categorizations and insights
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Secret key used for signing JWT tokens for user authentication
JWT_SECRET=your_super_secret_jwt_key_here
